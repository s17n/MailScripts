# PopClip DEVONthink Set Subject
name: Set Subject
icon: square Su
required apps: [com.devon-technologies.think]
applescript: | # pipe character begins a multi-line string
  set config to load script (POSIX path of (path to home folder) & ".mailscripts/config.scpt")
  set docLib to load script pDocLibraryPath of config    
  tell docLib to addTextToCustomMetadata("Subject", "{popclip text}")
# the above line    
